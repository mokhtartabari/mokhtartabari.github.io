---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { site } from "~/data/site";
import { ClientRouter } from "astro:transitions";

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const { title, description = site.description, image = "/img/profile.png" } = Astro.props;
const fullTitle = title ? `${title} — ${site.name}` : site.title;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/png" href="/img/icon.png" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2YL52NCZ30"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2YL52NCZ30');
    </script>
    <link rel="apple-touch-icon" href="/img/icon192.png" />

    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script is:inline>
      const applyTheme = () => {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const isDark = stored ? stored === "dark" : prefersDark;
        document.documentElement.classList.toggle("dark", isDark);
      };
      applyTheme();
      document.addEventListener("astro:after-swap", applyTheme);

      const checkExclusionParam = () => {
        try {
          const urlParams = new URLSearchParams(window.location.search);
          if (urlParams.has("exclude")) {
            const val = urlParams.get("exclude");
            if (val === "true") {
              localStorage.setItem("exclude_analytics", "true");
              alert("Self-Exclusion Enabled: This browser is now EXCLUDED from analytics tracking.");
            } else if (val === "false") {
              localStorage.removeItem("exclude_analytics");
              alert("Self-Exclusion Disabled: This browser is now INCLUDED in analytics tracking.");
            }
            const cleanUrl = window.location.pathname + window.location.hash;
            window.history.replaceState({}, document.title, cleanUrl);
          }
        } catch (e) {}
      };
      checkExclusionParam();
      document.addEventListener("astro:after-swap", checkExclusionParam);
    </script>

    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent-600 focus:text-white focus:rounded-lg"
      >Skip to main content</a
    >
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
