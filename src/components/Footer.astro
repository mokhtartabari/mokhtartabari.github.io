---
import SocialLinks from "~/components/SocialLinks.astro";
import { site } from "~/data/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-default mt-24">
  <div class="container-wide py-12 grid gap-10 md:grid-cols-3">
    <div class="space-y-2">
      <p class="font-serif text-lg font-semibold">{site.name}</p>
      <p class="text-sm text-muted">{site.position}</p>
      <p class="text-sm text-muted">{site.location}</p>
    </div>

    <div class="space-y-3">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-muted">
        Connect
      </h2>
      <SocialLinks size="sm" />
    </div>

    <div class="space-y-2 md:text-right">
      <p class="text-sm text-muted">
        <a
          href={`mailto:${site.email}`}
          class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
        >
          {site.email}
        </a>
      </p>
      <p class="text-sm text-muted">
        &copy; {year} {site.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
