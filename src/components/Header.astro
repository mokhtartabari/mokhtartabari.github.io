---
import ThemeToggle from "~/components/ThemeToggle.astro";
import { site } from "~/data/site";

const nav = [
  { label: "About", href: "/about/" },
  { label: "Publications", href: "/publications/" },
  { label: "Talks", href: "/talks/" },
  { label: "Blog", href: "/posts/" },
  { label: "Contact", href: "/contact/" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-40 backdrop-blur-md bg-[color-mix(in_srgb,var(--bg)_85%,transparent)] border-b border-default"
>
  <div class="container-wide flex items-center justify-between h-16">
    <a
      href="/"
      class="font-serif text-lg font-semibold tracking-tight hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
    >
      {site.name}
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
      {
        nav.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isActive =
            itemPath === pathname ||
            (itemPath !== "/" && pathname.startsWith(itemPath));
          return (
            <a
              href={item.href}
              class:list={[
                "relative px-3 py-2 text-sm font-medium rounded-md transition-colors",
                isActive
                  ? "text-accent-600 dark:text-accent-400"
                  : "text-muted hover:text-fg",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
              {isActive && (
                <span class="absolute -bottom-px left-3 right-3 h-px bg-accent-500" />
              )}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-md hover:bg-elevated transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden border-t border-default hidden bg-elevated"
  >
    <nav class="container-wide py-3 flex flex-col gap-1" aria-label="Mobile">
      {
        nav.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isActive =
            itemPath === pathname ||
            (itemPath !== "/" && pathname.startsWith(itemPath));
          return (
            <a
              href={item.href}
              class:list={[
                "px-3 py-2 rounded-md text-sm font-medium transition-colors",
                isActive
                  ? "text-accent-600 dark:text-accent-400 bg-accent-50 dark:bg-accent-900/30"
                  : "text-muted hover:text-fg hover:bg-elevated",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>

<script>
  const setupMobileMenu = () => {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    if (!toggle || !menu) return;
    toggle.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(!isOpen));
    });
  };
  setupMobileMenu();
  document.addEventListener("astro:page-load", setupMobileMenu);
</script>
