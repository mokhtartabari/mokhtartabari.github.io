---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { talks } from "~/data/talks";

const byYear = talks.reduce<Record<number, typeof talks>>((acc, talk) => {
  (acc[talk.year] ??= []).push(talk);
  return acc;
}, {});

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout
  title="Talks"
  description="Conference presentations and academic talks by Mokhtar Tabari."
>
  <section class="container-wide pt-16 pb-12">
    <header class="reveal max-w-3xl">
      <p
        class="text-xs font-medium tracking-widest uppercase text-accent-700 dark:text-accent-300 mb-3"
      >
        Talks & seminars
      </p>
      <h1
        class="font-serif text-4xl sm:text-5xl font-semibold leading-[1.1] tracking-tight"
      >
        Presentations
      </h1>
      <p class="mt-4 text-lg text-muted">
        A selection of conference talks and academic seminars.
      </p>
    </header>
  </section>

  <section class="container-wide pb-24">
    <div class="space-y-12">
      {
        years.map((year) => (
          <div class="reveal">
            <div class="flex items-baseline gap-4 mb-6">
              <h2 class="font-serif text-4xl font-semibold text-accent-700 dark:text-accent-300">
                {year}
              </h2>
              <span class="flex-1 h-px bg-default" />
              <span class="text-sm text-muted">
                {byYear[year].length} talk{byYear[year].length > 1 ? "s" : ""}
              </span>
            </div>
            <ul class="space-y-4" role="list">
              {byYear[year].map((talk) => (
                <li class="group rounded-xl border border-default bg-elevated p-5 hover:border-accent-400 dark:hover:border-accent-500 transition-all hover:-translate-y-0.5">
                  <h3 class="font-serif text-lg font-semibold leading-snug group-hover:text-accent-700 dark:group-hover:text-accent-300 transition-colors">
                    {talk.title}
                  </h3>
                  <p class="mt-2 text-sm text-muted">
                    <span class="font-medium text-fg">{talk.venue}</span>
                    <span class="block sm:inline">
                      <span class="hidden sm:inline"> · </span>
                      {talk.location}
                      <span> · </span>
                      <time class="text-muted">{talk.date}</time>
                    </span>
                  </p>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
