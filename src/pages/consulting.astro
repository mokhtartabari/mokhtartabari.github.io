---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { site } from "~/data/site";

const services = [
  {
    title: "Custom Data Dashboards & Visualizations",
    description: "Automated pipelines that ingest, parse, and render operational, financial, macroeconomic, or proprietary datasets into beautiful, custom, auto-updating charts and interactive dashboards (R, Python, D3.js).",
    icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="9" y1="3" x2="9" y2="21" /><line x1="15" y1="3" x2="15" y2="21" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="3" y1="15" x2="21" y2="15" />`
  },
  {
    title: "Policy & Program Impact Assessments",
    description: "Rigorous econometric assessments of trade dynamics, regulatory interventions, energy/environmental policy changes, or corporate program interventions to evaluate impact and guide strategy.",
    icon: `<circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />`
  },
  {
    title: "Strategic Analytics & Forecasting",
    description: "Dynamic scenario modeling, predictive analytics, and trend forecasting for market demand, housing, labor, inflation, or business operations to support corporate strategy and think tanks.",
    icon: `<line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" />`
  },
  {
    title: "Data Engineering & Analytics Pipelines",
    description: "Structuring messy data warehouses, setting up clean pipeline architectures (like this site's auto-syncing architecture), and automating data flows for real-time tracking.",
    icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2" />`
  }
];
---

<BaseLayout
  title="Consulting & Advisory Services"
  description="Rigorous data analysis, custom visualization pipelines, forecasting, and policy impact studies by Dr. Mokhtar Tabari."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-noise opacity-40 [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]" aria-hidden="true"></div>
    <div class="container-wide relative pt-16 pb-12 lg:pt-20 lg:pb-16 max-w-4xl text-center space-y-6">
      <p class="text-xs font-semibold tracking-widest uppercase text-accent-700 dark:text-accent-300">
        Data Consulting & Advisory
      </p>
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-semibold leading-tight tracking-tight">
        Rigorous Data Analysis & Visualization
      </h1>
      <p class="text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        I translate complex operational, corporate, or public datasets into evidence-based insights, custom forecasting models, and automated data pipelines for organizations and decision-makers across all sectors.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="container-wide pb-20">
    <div class="grid md:grid-cols-2 gap-6">
      {services.map((svc) => (
        <div class="reveal rounded-2xl border border-default bg-elevated p-6 sm:p-8 space-y-5 transition-all hover:border-accent-400 dark:hover:border-accent-500 hover:shadow-lg">
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-accent-50 dark:bg-accent-900/30 text-accent-600 dark:text-accent-300">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={svc.icon}
            />
          </span>
          <div class="space-y-2">
            <h2 class="font-serif text-xl font-semibold">{svc.title}</h2>
            <p class="text-sm text-muted leading-relaxed">{svc.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Conversion Section -->
  <section class="container-wide pb-24">
    <div class="grid lg:grid-cols-12 gap-8 items-start">
      
      <!-- Value Proposition & Pedigree -->
      <div class="lg:col-span-5 space-y-6 lg:sticky lg:top-24">
        <h2 class="font-serif text-3xl font-semibold tracking-tight">Rigorous Analysis. Evidence-Based Insights.</h2>
        <p class="text-sm text-muted leading-relaxed">
          Leveraging an academic foundation in applied econometrics and advanced statistics alongside modern data engineering, I bridge the gap between complex datasets and actionable business intelligence.
        </p>
        <ul class="space-y-3.5 text-sm" role="list">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong>PhD-level expertise</strong> in econometric modeling, causal inference, and data analysis.</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong>End-to-end automation</strong> (no manual spreadsheet copy-pasting; pipelines automatically sync with live feeds).</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong>Publication-grade styling</strong> ready to integrate directly into strategic presentations, briefs, or annual reports.</span>
          </li>
        </ul>
      </div>

      <!-- Inquiries Form -->
      <div class="lg:col-span-7 p-6 sm:p-8 rounded-2xl border border-default bg-elevated shadow-sm space-y-6">
        <div class="space-y-1">
          <h3 class="font-serif text-2xl font-semibold">Request a Proposal</h3>
          <p class="text-sm text-muted">Briefly describe your project needs. I will get back to you within 24–48 hours.</p>
        </div>

        <form id="consulting-form" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="name" class="text-xs font-semibold uppercase tracking-wider text-muted">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Jane Doe"
                class="w-full px-3.5 py-2.5 rounded-xl border border-default bg-surface text-sm focus:outline-none focus:ring-2 focus:ring-accent-500"
              />
            </div>
            <div class="space-y-1">
              <label for="email" class="text-xs font-semibold uppercase tracking-wider text-muted">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="jane@organization.com"
                class="w-full px-3.5 py-2.5 rounded-xl border border-default bg-surface text-sm focus:outline-none focus:ring-2 focus:ring-accent-500"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label for="org" class="text-xs font-semibold uppercase tracking-wider text-muted">Organization</label>
              <input
                type="text"
                id="org"
                name="org"
                placeholder="Company, Bank, Think Tank, NGO..."
                class="w-full px-3.5 py-2.5 rounded-xl border border-default bg-surface text-sm focus:outline-none focus:ring-2 focus:ring-accent-500"
              />
            </div>
            <div class="space-y-1">
              <label for="project-type" class="text-xs font-semibold uppercase tracking-wider text-muted">Project Focus</label>
              <select
                id="project-type"
                name="projectType"
                class="w-full px-3.5 py-2.5 rounded-xl border border-default bg-surface text-sm focus:outline-none focus:ring-2 focus:ring-accent-500"
              >
                <option value="Dashboard & Visualization">Custom Dashboard / Data Viz</option>
                <option value="Program Evaluation & Econometrics">Program Evaluation / Impact Study</option>
                <option value="Predictive Analytics & Forecasting">Forecasting / Scenario Modeling</option>
                <option value="Other / Advisory">General Consulting / Other</option>
              </select>
            </div>
          </div>

          <div class="space-y-1">
            <label for="message" class="text-xs font-semibold uppercase tracking-wider text-muted">Project Details & Timeline</label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              placeholder="Outline what questions you're trying to answer, the dataset required, and your timeline..."
              class="w-full px-3.5 py-2.5 rounded-xl border border-default bg-surface text-sm resize-y focus:outline-none focus:ring-2 focus:ring-accent-500"
            ></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <button
            type="submit"
            class="w-full py-3 rounded-xl bg-accent-600 hover:bg-accent-700 text-white font-semibold text-sm transition-all hover:shadow-lg hover:shadow-accent-500/25"
          >
            Submit Inquiry
          </button>
          
          <p id="form-status" class="text-xs text-center font-medium empty:hidden" role="status"></p>
        </form>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const formSetup = () => {
    const form = document.getElementById("consulting-form") as HTMLFormElement | null;
    const status = document.getElementById("form-status");

    if (!form || !status || !SB_URL || !SB_KEY) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      // Honeypot check
      if (formData.get("company")) return;

      const name = String(formData.get("name") || "").trim();
      const email = String(formData.get("email") || "").trim();
      const org = String(formData.get("org") || "").trim();
      const projectType = String(formData.get("projectType") || "");
      const details = String(formData.get("message") || "").trim();

      if (!name || !email || !details) return;

      status.textContent = "Submitting inquiry...";
      status.className = "text-xs text-center text-muted font-medium";

      const fullMessage = `[Consulting Request]\nName: ${name}\nOrganization: ${org || 'N/A'}\nProject Focus: ${projectType}\n\nDetails:\n${details}`;

      try {
        const res = await fetch(`${SB_URL}/rest/v1/feedback`, {
          method: "POST",
          headers: {
            apikey: SB_KEY,
            Authorization: `Bearer ${SB_KEY}`,
            "Content-Type": "application/json",
            Prefer: "return=minimal"
          },
          body: JSON.stringify({
            message: fullMessage,
            email: email
          })
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        form.reset();
        status.textContent = "Thank you! Your consulting request has been sent. Dr. Tabari will review and follow up shortly.";
        status.className = "text-xs text-center text-emerald-600 dark:text-emerald-400 font-medium";
      } catch (err) {
        console.warn("Consulting inquiry failed:", err);
        status.textContent = "Something went wrong. Please email directly or try again later.";
        status.className = "text-xs text-center text-rose-500 font-medium";
      }
    });
  };

  formSetup();
  document.addEventListener("astro:page-load", formSetup);
</script>
