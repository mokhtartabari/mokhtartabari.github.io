---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SocialLinks from "~/components/SocialLinks.astro";
import { site } from "~/data/site";

const contactMethods = [
  {
    label: "Email",
    value: site.email,
    href: `mailto:${site.email}`,
    svg: `<path d="M3 7l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    label: "Office",
    value: "1461 Granville St., Vancouver, BC V6Z 2V3",
    href: "https://maps.google.com/?q=1461+Granville+St+Vancouver+BC",
    svg: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />`,
  },
  {
    label: "Phone",
    value: "+1 (778) 725-1358",
    href: "tel:+17787251358",
    svg: `<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />`,
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Dr. Mokhtar Tabari."
>
  <section class="container-wide pt-16 pb-12">
    <header class="reveal max-w-3xl">
      <p
        class="text-xs font-medium tracking-widest uppercase text-accent-700 dark:text-accent-300 mb-3"
      >
        Say hello
      </p>
      <h1
        class="font-serif text-4xl sm:text-5xl font-semibold leading-[1.1] tracking-tight"
      >
        Get in touch
      </h1>
      <p class="mt-4 text-lg text-muted">
        I welcome inquiries about research collaboration, guest lectures, media,
        and student supervision. Email is the fastest way to reach me.
      </p>
    </header>
  </section>

  <section class="container-wide pb-12">
    <div class="grid lg:grid-cols-2 gap-6">
      {
        contactMethods.map((method) => (
          <a
            href={method.href}
            target={method.href.startsWith("http") ? "_blank" : undefined}
            rel={method.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="reveal group flex items-start gap-4 rounded-2xl border border-default bg-elevated p-6 hover:border-accent-400 dark:hover:border-accent-500 transition-all hover:-translate-y-1 hover:shadow-[0_12px_40px_-12px_rgba(99,102,241,0.25)]"
          >
            <span class="flex items-center justify-center w-12 h-12 rounded-xl bg-accent-50 dark:bg-accent-900/40 text-accent-600 dark:text-accent-300 flex-shrink-0">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={method.svg}
              />
            </span>
            <div class="min-w-0">
              <p class="text-xs font-medium uppercase tracking-wider text-muted mb-1">
                {method.label}
              </p>
              <p class="font-medium text-fg group-hover:text-accent-700 dark:group-hover:text-accent-300 transition-colors break-words">
                {method.value}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container-wide pb-24">
    <div
      class="reveal rounded-2xl border border-default bg-elevated p-8 text-center"
    >
      <h2 class="font-serif text-2xl font-semibold mb-3">Find me online</h2>
      <p class="text-muted mb-6">
        I'm most active on Google Scholar and LinkedIn.
      </p>
      <div class="flex justify-center">
        <SocialLinks size="md" showLabels />
      </div>
    </div>
  </section>
</BaseLayout>
