---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { site } from "~/data/site";

export async function getStaticPaths() {
  const posts = (await getCollection("posts")).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="container-prose pt-16 pb-24">
    <header class="reveal mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-4 text-sm">
        <a
          href="/posts/"
          class="text-accent-600 dark:text-accent-400 hover:underline"
        >
          ← All posts
        </a>
        {
          post.data.category && (
            <span class="text-xs font-medium tracking-wider uppercase text-accent-700 dark:text-accent-300 px-2 py-1 rounded-full bg-accent-50 dark:bg-accent-900/40">
              {post.data.category}
            </span>
          )
        }
      </div>
      <h1
        class="font-serif text-4xl sm:text-5xl font-semibold leading-[1.1] tracking-tight"
      >
        {post.data.title}
      </h1>
      <p class="mt-4 text-lg text-muted">{post.data.description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-muted">
        <span class="font-medium text-fg">{site.name}</span>
        <span>·</span>
        <time datetime={post.data.date.toISOString()}>
          {
            post.data.date.toLocaleDateString("en-CA", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
      </div>
    </header>

    <div class="reveal prose-academic">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-default">
      <a
        href="/posts/"
        class="inline-flex items-center gap-2 text-sm font-medium text-accent-600 dark:text-accent-400 hover:underline"
      >
        ← Back to all posts
      </a>
    </footer>
  </article>
</BaseLayout>
