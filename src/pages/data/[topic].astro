---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { vizTopics, type VizManifest } from "~/data/visualizations";
import inflationManifest from "~/data/charts-manifest-inflation.json";
import gdpManifest from "~/data/charts-manifest-gdp.json";

export function getStaticPaths() {
  return vizTopics.map((t) => ({ params: { topic: t.slug } }));
}

const { topic: topicSlug } = Astro.params;
const topic = vizTopics.find((t) => t.slug === topicSlug)!;

const manifestMap: Record<string, VizManifest> = {
  inflation: inflationManifest as unknown as VizManifest,
  gdp: gdpManifest as unknown as VizManifest,
};
const manifest = manifestMap[topicSlug!];
const charts = manifest.charts;

const rawCategories = [...new Set(charts.map((c) => c.category).filter(Boolean))];
const hasCategories = rawCategories.length > 1;

// Preferred reading order for category sections/filter (unknown categories appended).
const CATEGORY_ORDER = ["Overview", "Per Capita", "Provincial", "Sectors", "Industries", "Cyclical"];
const catRank = (c: string) => {
  const i = CATEGORY_ORDER.indexOf(c);
  return i === -1 ? CATEGORY_ORDER.length : i;
};
const orderedCats = [...rawCategories].sort(
  (a, b) => catRank(a) - catRank(b) || rawCategories.indexOf(a) - rawCategories.indexOf(b),
);
const categories = hasCategories ? ["All", ...orderedCats] : [];

// Charts grouped by category (in CATEGORY_ORDER), preserving publish.yml order within each.
const groups = hasCategories
  ? orderedCats.map((cat) => ({ cat, items: charts.filter((c) => (c.category ?? "") === cat) }))
  : [{ cat: null as string | null, items: charts }];

function fmtDate(iso: string | null) {
  if (!iso) return null;
  return new Date(iso).toLocaleDateString("en-CA", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
const updated = fmtDate(manifest.updated);

function slugToTitle(slug: string) {
  return slug
    .replace(/_/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}
---

<BaseLayout
  title={topic.title}
  description={`${topic.description} High-quality charts generated from Statistics Canada data.`}
>
  <!-- Breadcrumb --------------------------------------------------------->
  <div class="container-wide pt-8 pb-0">
    <nav class="flex items-center gap-2 text-sm text-muted" aria-label="Breadcrumb">
      <a href="/data/" class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors">
        Charts
      </a>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="opacity-40">
        <path d="M9 18l6-6-6-6"/>
      </svg>
      <span class="text-fg">{topic.title}</span>
    </nav>
  </div>

  <!-- Header ------------------------------------------------------------->
  <section class="container-wide pt-8 pb-10">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <header class="reveal max-w-2xl">
        <h1 class="font-serif text-4xl sm:text-5xl font-semibold leading-[1.1] tracking-tight mb-4">
          {topic.title}
        </h1>
        <p class="text-base text-muted leading-relaxed">
          {topic.longDescription}
        </p>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-5 text-sm text-muted">
          {updated && (
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Updated {updated}
            </span>
          )}
          {charts.length > 0 && (
            <span>{charts.length} charts</span>
          )}
          <a
            href={topic.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-accent-600 dark:text-accent-400 hover:underline font-medium"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            {topic.repoLabel}
          </a>
        </div>
      </header>
    </div>
  </section>

  <!-- Category filter (shown only when categories exist) ---------------->
  {
    hasCategories && (
      <div class="container-wide mb-8">
        <div
          id="category-filter"
          class="flex flex-wrap gap-2"
          role="group"
          aria-label="Filter by category"
        >
          {categories.map((cat, i) => (
            <button
              class="category-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-150 border"
              data-category={cat}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>
    )
  }

  <!-- Chart grid --------------------------------------------------------->
  <section class="container-wide pb-24">
    {
      charts.length === 0 ? (
        /* Empty state */
        <div class="reveal flex flex-col items-center justify-center py-28 text-center">
          <div class="w-16 h-16 rounded-2xl border border-default bg-elevated flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted" aria-hidden="true">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <h2 class="font-serif text-xl font-semibold mb-2">Charts are on their way</h2>
          <p class="text-muted text-sm max-w-sm leading-relaxed">
            The automated workflow is being configured. Charts will appear here automatically once the first data pipeline run completes.
          </p>
          <a
            href={topic.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-sm text-accent-600 dark:text-accent-400 hover:underline font-medium"
          >
            Follow progress on GitHub
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      ) : (
        <div
          id="chart-grid"
          class="grid sm:grid-cols-2 gap-6"
        >
          {groups.map((group) => (
            <>
              {group.cat && (
                <h2
                  class="category-heading sm:col-span-2 font-serif text-lg font-semibold tracking-tight mt-4 first:mt-0 pb-1.5 border-b border-default"
                  data-category={group.cat}
                >
                  {group.cat}
                </h2>
              )}
              {group.items.map((chart, i) => {
                const title = chart.title ?? slugToTitle(chart.slug);
                const caption = chart.description || title;
                return (
                <figure
                  class="reveal chart-card group relative rounded-2xl border border-default bg-elevated overflow-hidden cursor-zoom-in hover:border-accent-200 dark:hover:border-accent-800 hover:shadow-xl transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500"
                  data-category={chart.category ?? ""}
                  data-title={title}
                  data-caption={caption}
                  role="button"
                  tabindex="0"
                  aria-label={`Open chart: ${title}`}
                  style={`animation-delay:${(i % 6) * 60}ms`}
                >
                  <div class="overflow-hidden" style="background-color: var(--chart-bg)">
                    <img
                      src={`${topic.chartsDir}${chart.filename}`}
                      alt={title}
                      class="w-full h-auto block transition-transform duration-500 group-hover:scale-[1.02]"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <figcaption class="px-4 py-3 flex items-start justify-between gap-3">
                    <span class="text-sm leading-snug text-muted">
                      {caption}
                    </span>
                    {chart.category && (
                      <span class="flex-shrink-0 text-[11px] font-medium px-2 py-0.5 rounded-full bg-accent-50 dark:bg-accent-900/30 text-accent-700 dark:text-accent-300">
                        {chart.category}
                      </span>
                    )}
                  </figcaption>
                  {/* Expand hint */}
                  <div class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity">
                    <div class="bg-black/50 text-white rounded-lg p-1.5 backdrop-blur-sm">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                    </div>
                  </div>
                </figure>
                );
              })}
            </>
          ))}
        </div>
      )
    }
  </section>

  <!-- Lightbox ---------------------------------------------------------->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center p-4 md:p-8"
    role="dialog"
    aria-modal="true"
    aria-label="Chart lightbox"
  >
    <!-- Backdrop -->
    <div id="lb-backdrop" class="absolute inset-0 bg-black/85 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative z-10 w-full max-w-5xl flex flex-col gap-3 max-h-[95vh]">
      <!-- Top bar -->
      <div class="flex items-center justify-between px-1">
        <span id="lb-counter" class="text-white/60 text-sm tabular-nums"></span>
        <div class="flex items-center gap-2">
          <a
            id="lb-download"
            download
            class="inline-flex items-center gap-1.5 text-sm text-white/70 hover:text-white px-3 py-1.5 rounded-lg border border-white/20 hover:border-white/40 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download PNG
          </a>
          <button
            id="lb-close"
            class="p-1.5 rounded-lg text-white/70 hover:text-white border border-white/20 hover:border-white/40 transition-colors"
            aria-label="Close lightbox"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>

      <!-- Image -->
      <div class="relative flex items-center justify-center">
        <button
          id="lb-prev"
          class="absolute left-0 z-10 -translate-x-2 md:-translate-x-12 p-2 rounded-xl text-white/70 hover:text-white border border-white/20 hover:border-white/40 bg-black/40 hover:bg-black/60 transition-all"
          aria-label="Previous chart"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>

        <img
          id="lb-img"
          src=""
          alt=""
          class="max-w-full max-h-[75vh] object-contain rounded-xl shadow-2xl p-3"
          style="background-color: var(--chart-bg)"
        />

        <button
          id="lb-next"
          class="absolute right-0 z-10 translate-x-2 md:translate-x-12 p-2 rounded-xl text-white/70 hover:text-white border border-white/20 hover:border-white/40 bg-black/40 hover:bg-black/60 transition-all"
          aria-label="Next chart"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>

      <!-- Caption -->
      <p id="lb-caption" class="text-center text-white/80 text-sm px-8"></p>
    </div>
  </div>
</BaseLayout>

<style>
  /* Category filter buttons */
  .category-btn {
    background-color: var(--bg-elevated);
    border-color: var(--border);
    color: var(--fg-muted);
  }
  .category-btn:hover,
  .category-btn[aria-pressed="true"] {
    background-color: var(--color-accent-600);
    border-color: var(--color-accent-600);
    color: white;
  }
  .dark .category-btn:hover,
  .dark .category-btn[aria-pressed="true"] {
    background-color: var(--color-accent-500);
    border-color: var(--color-accent-500);
  }
  .chart-card[data-hidden],
  .category-heading[data-hidden] {
    display: none;
  }
</style>

<script>
  // ── Category filter ──────────────────────────────────────────────────
  const filterSetup = () => {
    const btns = document.querySelectorAll<HTMLButtonElement>(".category-btn");
    const cards = document.querySelectorAll<HTMLElement>(".chart-card");
    const headings = document.querySelectorAll<HTMLElement>(".category-heading");
    if (!btns.length) return;

    btns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.category ?? "All";
        btns.forEach((b) => b.setAttribute("aria-pressed", "false"));
        btn.setAttribute("aria-pressed", "true");

        cards.forEach((card) => {
          if (cat === "All" || card.dataset.category === cat) {
            card.removeAttribute("data-hidden");
          } else {
            card.setAttribute("data-hidden", "");
          }
        });
        // Section headings only make sense in the "All" view.
        headings.forEach((h) => {
          if (cat === "All") h.removeAttribute("data-hidden");
          else h.setAttribute("data-hidden", "");
        });
      });
    });
  };

  // ── Lightbox ─────────────────────────────────────────────────────────
  const lightboxSetup = () => {
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>(".chart-card"),
    );
    const lb = document.getElementById("lightbox")!;
    const lbImg = document.getElementById("lb-img") as HTMLImageElement;
    const lbCaption = document.getElementById("lb-caption")!;
    const lbCounter = document.getElementById("lb-counter")!;
    const lbDownload = document.getElementById("lb-download") as HTMLAnchorElement;
    const lbClose = document.getElementById("lb-close")!;
    const lbPrev = document.getElementById("lb-prev")!;
    const lbNext = document.getElementById("lb-next")!;
    const lbBackdrop = document.getElementById("lb-backdrop")!;

    if (!lb || !cards.length) return;

    // Visible cards only (respects category filter)
    const visibleCards = () =>
      cards.filter((c) => !c.hasAttribute("data-hidden"));

    let current = 0;

    const open = (idx: number) => {
      const pool = visibleCards();
      if (!pool.length) return;
      current = ((idx % pool.length) + pool.length) % pool.length;
      const card = pool[current];
      const img = card.querySelector("img")!;
      const caption = card.dataset.caption ?? "";
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      lbCaption.textContent = caption;
      lbCounter.textContent = `${current + 1} / ${pool.length}`;
      lbDownload.href = img.src;
      lbDownload.download = img.src.split("/").pop() ?? "chart.png";
      lb.classList.remove("hidden");
      lb.classList.add("flex");
      document.body.style.overflow = "hidden";
      lbClose.focus();
    };

    const close = () => {
      lb.classList.add("hidden");
      lb.classList.remove("flex");
      document.body.style.overflow = "";
    };

    cards.forEach((card) => {
      const openCard = () => {
        const pool = visibleCards();
        const poolIdx = pool.indexOf(card);
        open(poolIdx >= 0 ? poolIdx : 0);
      };
      card.addEventListener("click", openCard);
      card.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          openCard();
        }
      });
    });

    lbClose.addEventListener("click", close);
    lbBackdrop.addEventListener("click", close);
    lbPrev.addEventListener("click", () => open(current - 1));
    lbNext.addEventListener("click", () => open(current + 1));

    document.addEventListener("keydown", (e) => {
      if (lb.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") open(current - 1);
      if (e.key === "ArrowRight") open(current + 1);
    });

    // Touch swipe
    let touchStartX = 0;
    lb.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
    });
    lb.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) open(dx < 0 ? current + 1 : current - 1);
    });
  };

  filterSetup();
  lightboxSetup();
  document.addEventListener("astro:page-load", () => {
    filterSetup();
    lightboxSetup();
  });
</script>
