---
import BaseLayout from "~/layouts/BaseLayout.astro";
import {
  bio,
  education,
  experience,
  awards,
  otherExperience,
} from "~/data/about";
import { appointments, interests as teachingInterests } from "~/data/teaching";
import { site } from "~/data/site";
---

<BaseLayout title="About" description="Biography, education, experience, and teaching record of Dr. Mokhtar Tabari.">
  <section class="container-wide pt-16 pb-12">
    <header class="reveal max-w-3xl">
      <p
        class="text-xs font-medium tracking-widest uppercase text-accent-700 dark:text-accent-300 mb-3"
      >
        About
      </p>
      <h1
        class="font-serif text-4xl sm:text-5xl font-semibold leading-[1.1] tracking-tight"
      >
        A short biography
      </h1>
    </header>
  </section>

  <section class="container-wide pb-16">
    <div class="grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-8 space-y-5 text-[17px] leading-relaxed text-fg">
        {bio.map((p) => <p class="reveal" set:html={p} />)}
      </div>

      <aside class="lg:col-span-4 space-y-6">
        <div class="reveal rounded-2xl border border-default bg-elevated p-6">
          <h2 class="font-serif text-lg font-semibold mb-3">Research interests</h2>
          <ul class="space-y-2" role="list">
            {
              site.researchInterests.map((interest) => (
                <li class="flex items-start gap-2 text-sm">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent-500 flex-shrink-0" />
                  <span>{interest}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="reveal rounded-2xl border border-default bg-elevated p-6">
          <h2 class="font-serif text-lg font-semibold mb-3">Quick contact</h2>
          <p class="text-sm text-muted mb-2">{site.location}</p>
          <a
            href={`mailto:${site.email}`}
            class="text-sm text-accent-600 dark:text-accent-400 hover:underline break-all block mb-4"
          >
            {site.email}
          </a>
        </div>
        <div class="reveal rounded-2xl border border-default bg-elevated p-6">
          <h2 class="font-serif text-lg font-semibold mb-3">Consulting & Advisory</h2>
          <p class="text-xs text-muted leading-relaxed mb-4">
            Available for custom macroeconomic data visualization, dashboard engineering, forecasting, and trade/policy impact studies.
          </p>
          <a
            href="/consulting/"
            class="inline-flex items-center gap-1 text-xs font-semibold text-accent-600 dark:text-accent-400 hover:underline"
          >
            Learn more & request proposal →
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Education -->
  <section class="container-wide py-12">
    <h2 class="reveal font-serif text-3xl font-semibold mb-8">Education</h2>
    <ol class="reveal relative space-y-6 border-l-2 border-default pl-6" role="list">
      {
        education.map((edu) => (
          <li class="relative">
            <span class="absolute -left-[33px] top-1.5 w-4 h-4 rounded-full bg-elevated border-2 border-accent-500" />
            <div class="flex flex-wrap justify-between items-baseline gap-2">
              <h3 class="font-semibold text-lg">{edu.degree}</h3>
              <span class="text-sm text-muted">{edu.year}</span>
            </div>
            <p class="text-muted">{edu.institution}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Experience -->
  <section class="container-wide py-12">
    <h2 class="reveal font-serif text-3xl font-semibold mb-8">
      Professional experience
    </h2>
    <ol class="reveal relative space-y-6 border-l-2 border-default pl-6" role="list">
      {
        experience.map((exp) => (
          <li class="relative">
            <span class="absolute -left-[33px] top-1.5 w-4 h-4 rounded-full bg-elevated border-2 border-accent-500" />
            <div class="flex flex-wrap justify-between items-baseline gap-2">
              <h3 class="font-semibold text-lg">{exp.role}</h3>
              <span class="text-sm text-muted">{exp.period}</span>
            </div>
            <p class="text-muted">
              {exp.org}
              <span class="text-muted/70"> · {exp.location}</span>
            </p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Awards -->
  <section class="container-wide py-12">
    <h2 class="reveal font-serif text-3xl font-semibold mb-8">
      Awards & recognitions
    </h2>
    <ul class="reveal grid sm:grid-cols-2 gap-3" role="list">
      {
        awards.map((award) => (
          <li class="rounded-xl border border-default bg-elevated p-4 flex items-start gap-3">
            <span class="text-gold-500 mt-0.5" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M12 2l2.4 7.2h7.6l-6.2 4.5 2.4 7.3L12 16.6l-6.2 4.4 2.4-7.3L2 9.2h7.6L12 2z" />
              </svg>
            </span>
            <div>
              <p class="font-medium text-fg leading-snug">{award.name}</p>
              <p class="text-sm text-muted mt-0.5">
                {award.org && <span>{award.org}, </span>}
                {award.year}
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Other experience -->
  <section class="container-wide py-12">
    <h2 class="reveal font-serif text-3xl font-semibold mb-8">Other experience</h2>
    <ul class="reveal space-y-3" role="list">
      {
        otherExperience.map((exp) => (
          <li class="flex flex-wrap justify-between items-baseline gap-2 py-2 border-b border-default last:border-0">
            <div>
              <span class="font-medium">{exp.role}</span>
              <span class="text-muted"> · {exp.org}</span>
            </div>
            <span class="text-sm text-muted">{exp.period}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Teaching summary -->
  <section class="container-wide py-12 pb-24">
    <div class="reveal flex flex-wrap items-baseline justify-between gap-3 mb-8">
      <h2 class="font-serif text-3xl font-semibold">Teaching</h2>
      <a
        href="/teaching/"
        class="text-sm font-medium text-accent-600 dark:text-accent-400 hover:underline"
      >
        Full teaching record →
      </a>
    </div>

    <div class="reveal grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
      {
        appointments.map((app) => (
          <article class="rounded-xl border border-default bg-elevated p-5 hover:border-accent-400 dark:hover:border-accent-500 transition-colors">
            <h3 class="font-serif font-semibold text-base leading-snug">
              {app.institution}
            </h3>
            <p class="text-sm text-muted mt-1">{app.role}</p>
            <p class="text-xs text-muted mt-1">{app.period}</p>
            <p class="text-xs text-muted mt-3 pt-3 border-t border-default">
              {app.courses.length} course{app.courses.length > 1 ? "s" : ""}
            </p>
          </article>
        ))
      }
    </div>

    <div class="reveal">
      <p class="text-sm text-muted mb-3 uppercase tracking-wider font-medium">
        Areas of teaching
      </p>
      <ul class="flex flex-wrap gap-2" role="list">
        {
          teachingInterests.map((t) => (
            <li class="text-sm px-3 py-1.5 rounded-full border border-default bg-elevated text-fg">
              {t}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
