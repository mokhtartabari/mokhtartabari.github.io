---
// Per-chart share page: /charts/<topic>/<slug>/
//
// The canonical shareable URL for a single chart. Its Open Graph / Twitter
// meta points at the chart PNG itself, so pasting this link on X, LinkedIn,
// Bluesky, Reddit, or a group chat unfurls into a large chart card that
// clicks through to THIS page — chrome, context, downloads, and the rest of
// the site included.
import BaseLayout from "~/layouts/BaseLayout.astro";
import { vizTopics, type VizManifest, type ChartEntry, type VizTopic } from "~/data/visualizations";
import inflationManifest from "~/data/charts-manifest-inflation.json";
import gdpManifest from "~/data/charts-manifest-gdp.json";
import tradeManifest from "~/data/charts-manifest-trade.json";
import employmentManifest from "~/data/charts-manifest-employment.json";
import productivityManifest from "~/data/charts-manifest-productivity.json";
import ratesManifest from "~/data/charts-manifest-rates.json";
import housingManifest from "~/data/charts-manifest-housing.json";
import energyManifest from "~/data/charts-manifest-energy.json";

export function getStaticPaths() {
  const map: Record<string, VizManifest> = {
    inflation: inflationManifest as unknown as VizManifest,
    gdp: gdpManifest as unknown as VizManifest,
    trade: tradeManifest as unknown as VizManifest,
    employment: employmentManifest as unknown as VizManifest,
    productivity: productivityManifest as unknown as VizManifest,
    rates: ratesManifest as unknown as VizManifest,
    housing: housingManifest as unknown as VizManifest,
    energy: energyManifest as unknown as VizManifest,
  };
  const paths: { params: { topic: string; slug: string }; props: { chart: ChartEntry; topic: VizTopic } }[] = [];
  for (const t of vizTopics) {
    for (const c of map[t.slug]?.charts ?? []) {
      paths.push({ params: { topic: t.slug, slug: c.slug }, props: { chart: c, topic: t } });
    }
  }
  return paths;
}

const { chart, topic } = Astro.props as { chart: ChartEntry; topic: VizTopic };

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const chartImg = `${topic.chartsDir}${chart.filename}`;
const base = chart.filename.replace(/\.png$/i, "");
const formats = chart.formats ?? ["png"];

const shareText = encodeURIComponent(`${chart.title} — updated automatically from Statistics Canada data`);
const shareUrl = encodeURIComponent(pageUrl);
---

<BaseLayout
  title={chart.title}
  description={chart.description || `${chart.title} — auto-updated chart from official Canadian data.`}
  image={chartImg}
>
  <section class="container-wide pt-10 pb-16">
    <nav class="reveal text-sm text-muted mb-6">
      <a href="/charts/" class="hover:text-accent-600 dark:hover:text-accent-400">Charts</a>
      <span class="mx-1">/</span>
      <a href={`/charts/${topic.slug}/`} class="hover:text-accent-600 dark:hover:text-accent-400">{topic.title}</a>
      <span class="mx-1">/</span>
      <span class="text-fg">{chart.title}</span>
    </nav>

    <header class="reveal max-w-3xl mb-6">
      <div class="flex flex-wrap items-center gap-2 mb-2">
        {chart.insight && (
          <span class="inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-0.5 rounded-full bg-gold-500 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l2.4 7.2h7.6l-6.2 4.5 2.4 7.3L12 16.6l-6.2 4.4 2.4-7.3L2 9.2h7.6L12 2z" />
            </svg>
            Original analysis
          </span>
        )}
        {chart.category && (
          <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-accent-50 dark:bg-accent-900/30 text-accent-700 dark:text-accent-300">
            {chart.category}
          </span>
        )}
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold leading-tight tracking-tight">
        {chart.title}
      </h1>
      {chart.description && (
        <p class="mt-2 text-muted">{chart.description}</p>
      )}
    </header>

    <figure class="reveal rounded-2xl border border-default bg-elevated overflow-hidden max-w-4xl">
      <div style="background-color: var(--chart-bg)">
        <img src={chartImg} alt={chart.title} class="w-full h-auto block" loading="eager" />
      </div>
      <figcaption class="px-5 py-4 space-y-1.5">
        {chart.note && (
          <p class="text-sm leading-snug text-muted/90 italic">How to read: {chart.note}</p>
        )}
        {chart.data_through && (
          <p class="text-xs text-muted/70">
            Data through {chart.data_through} · updates automatically when Statistics Canada releases new data
          </p>
        )}
      </figcaption>
    </figure>

    <div class="reveal mt-6 max-w-4xl flex flex-wrap items-center gap-2">
      <span class="text-sm text-muted mr-1">Share:</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`}
        target="_blank" rel="noopener noreferrer" aria-label="Share on X" title="Share on X"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
      </a>
      <a
        href={`https://bsky.app/intent/compose?text=${shareText}%20${shareUrl}`}
        target="_blank" rel="noopener noreferrer" aria-label="Share on Bluesky" title="Share on Bluesky"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/></svg>
      </a>
      <a
        href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}
        target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" title="Share on LinkedIn"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
      </a>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
        target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" title="Share on Facebook"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a
        href={`https://wa.me/?text=${shareText}%20${shareUrl}`}
        target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp" title="Share on WhatsApp"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
      </a>
      <a
        href={`https://www.reddit.com/submit?url=${shareUrl}&title=${shareText}`}
        target="_blank" rel="noopener noreferrer" aria-label="Share on Reddit" title="Share on Reddit"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 01-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 01.042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 014.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 01.14-.197.35.35 0 01.238-.042l2.906.617a1.214 1.214 0 011.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 00-.231.094.33.33 0 000 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 00.029-.463.33.33 0 00-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 00-.232-.095z"/></svg>
      </a>
      <a
        href={`mailto:?subject=${shareText}&body=${shareUrl}`}
        aria-label="Share by email" title="Share by email"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
      <button
        id="native-share"
        data-url={pageUrl}
        data-title={chart.title}
        aria-label="More sharing options" title="More sharing options"
        class="hidden p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
      </button>
      <button
        id="copy-link"
        data-url={pageUrl}
        aria-label="Copy link" title="Copy link"
        class="p-2 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
      </button>
      <span class="mx-2 text-muted/40">|</span>
      <span class="text-sm text-muted mr-1">Download:</span>
      {formats.map((f) => (
        <a
          href={`${topic.chartsDir}${base}.${f}`}
          download
          class="text-sm px-3 py-1.5 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 uppercase transition-colors"
        >{f}</a>
      ))}
      {chart.csv && (
        <a
          href={`${topic.chartsDir}${base}.csv`}
          download
          class="text-sm px-3 py-1.5 rounded-lg border border-default bg-elevated hover:border-accent-400 dark:hover:border-accent-500 transition-colors"
        >CSV (data)</a>
      )}
    </div>

    <p class="reveal mt-3 text-xs text-muted max-w-4xl">
      Free to use with attribution — CC BY 4.0. High-resolution formats above; the
      CSV carries the exact series behind the chart.
    </p>

    <div class="reveal mt-10 max-w-4xl rounded-2xl border border-default bg-elevated p-6">
      <h2 class="font-serif text-lg font-semibold mb-1">More {topic.title.toLowerCase()} charts</h2>
      <p class="text-sm text-muted mb-3">{topic.description}</p>
      <a
        href={`/charts/${topic.slug}/`}
        class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-600 dark:text-accent-400 hover:underline"
      >
        View all {topic.title} charts →
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const bindCopy = () => {
    const btn = document.getElementById("copy-link") as HTMLButtonElement | null;
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.url || location.href);
        const old = btn.innerHTML;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => (btn.innerHTML = old), 1500);
      } catch { /* clipboard unavailable */ }
    });
  };
  const bindNative = () => {
    const btn = document.getElementById("native-share") as HTMLButtonElement | null;
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = "1";
    if (!navigator.share) return;   // stays hidden where unsupported
    btn.classList.remove("hidden");
    btn.addEventListener("click", () => {
      navigator.share({ title: btn.dataset.title || document.title, url: btn.dataset.url || location.href }).catch(() => {});
    });
  };
  document.addEventListener("astro:page-load", () => { bindCopy(); bindNative(); });
</script>
