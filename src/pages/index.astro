---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import SocialLinks from "~/components/SocialLinks.astro";
import PublicationCard from "~/components/PublicationCard.astro";
import { site } from "~/data/site";

const allPublications = await getCollection("publications");
const featured = allPublications
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const recentPosts = (await getCollection("posts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="absolute inset-0 grid-noise opacity-60 [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -top-32 -right-32 w-96 h-96 bg-accent-500/20 dark:bg-accent-500/10 rounded-full blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -bottom-32 -left-32 w-96 h-96 bg-accent-400/10 rounded-full blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div
      class="container-wide relative pt-16 pb-20 lg:pt-24 lg:pb-32 grid lg:grid-cols-12 gap-12 items-center"
    >
      <div class="lg:col-span-7 space-y-6">
        <p
          class="reveal inline-flex items-center gap-2 text-xs font-medium tracking-widest uppercase text-accent-700 dark:text-accent-300"
        >
          <span class="w-8 h-px bg-accent-500"></span>
          {site.position}
        </p>

        <h1
          class="reveal font-serif text-5xl sm:text-6xl lg:text-7xl font-semibold leading-[1.05] tracking-tight"
        >
          {site.name}
        </h1>

        <p class="reveal text-lg sm:text-xl text-muted max-w-2xl leading-relaxed">
          Economist researching <span class="text-fg font-medium"
            >international trade</span
          >, <span class="text-fg font-medium">energy & environmental policy</span
          >, and the economics of <span class="text-fg font-medium"
            >artificial intelligence</span
          >. Based in {site.location}.
        </p>

        <div class="reveal flex flex-wrap gap-3 pt-2">
          <a
            href="/about/"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent-600 hover:bg-accent-700 text-white font-medium text-sm transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-accent-500/25"
          >
            About me
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a
            href="/publications/"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-default bg-elevated hover:bg-accent-50 dark:hover:bg-accent-900/20 hover:border-accent-400 dark:hover:border-accent-500 font-medium text-sm transition-all hover:-translate-y-0.5"
          >
            Research
          </a>
          <a
            href={site.cv}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-default bg-elevated hover:bg-accent-50 dark:hover:bg-accent-900/20 hover:border-accent-400 dark:hover:border-accent-500 font-medium text-sm transition-all hover:-translate-y-0.5"
          >
            CV
          </a>
        </div>

        <div class="reveal pt-4">
          <SocialLinks size="md" />
        </div>
      </div>

      <div class="reveal lg:col-span-5 flex justify-center lg:justify-end">
        <div class="relative">
          <div
            class="absolute -inset-3 bg-gradient-to-tr from-accent-500/40 via-accent-400/20 to-transparent rounded-full blur-2xl"
            aria-hidden="true"
          >
          </div>
          <div
            class="relative w-64 h-64 sm:w-72 sm:h-72 lg:w-80 lg:h-80 rounded-full overflow-hidden ring-4 ring-accent-500/30 ring-offset-4 ring-offset-[var(--bg)] shadow-2xl"
          >
            <img
              src="/img/profile.png"
              alt={`Portrait of ${site.name}`}
              width="320"
              height="320"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Research focus -->
  <section class="container-wide py-16">
    <div class="reveal grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        site.researchInterests.map((interest, i) => (
          <div class="group relative rounded-xl border border-default bg-elevated p-5 hover:border-accent-400 dark:hover:border-accent-500 transition-all hover:-translate-y-1">
            <span class="font-serif text-3xl text-accent-500/40 group-hover:text-accent-500 transition-colors block">
              0{i + 1}
            </span>
            <p class="mt-2 font-medium text-fg">{interest}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Affiliations -->
  <section class="container-wide py-8">
    <div class="reveal flex flex-wrap items-center justify-center gap-x-10 gap-y-4 text-sm text-muted">
      <span class="font-medium uppercase tracking-wider text-xs">
        Currently at
      </span>
      {
        site.institutions.map((inst) => (
          <a
            href={inst.url}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
          >
            <span class="font-serif text-lg">{inst.name}</span>
            <span class="block text-xs">{inst.role}</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Featured research -->
  {
    featured.length > 0 && (
      <section class="container-wide py-16 lg:py-24">
        <div class="reveal flex items-baseline justify-between flex-wrap gap-4 mb-10">
          <div>
            <p class="text-xs font-medium tracking-widest uppercase text-accent-700 dark:text-accent-300 mb-2">
              Featured
            </p>
            <h2 class="font-serif text-3xl sm:text-4xl font-semibold">
              Selected research
            </h2>
          </div>
          <a
            href="/publications/"
            class="text-sm font-medium text-accent-600 dark:text-accent-400 hover:underline"
          >
            All publications →
          </a>
        </div>
        <div class="grid lg:grid-cols-2 gap-6">
          {featured.map((p) => (
            <PublicationCard publication={p} />
          ))}
        </div>
      </section>
    )
  }

  <!-- Latest writing -->
  {
    recentPosts.length > 0 && (
      <section class="container-wide py-16 lg:py-20">
        <div class="reveal flex items-baseline justify-between flex-wrap gap-4 mb-10">
          <div>
            <p class="text-xs font-medium tracking-widest uppercase text-accent-700 dark:text-accent-300 mb-2">
              Writing
            </p>
            <h2 class="font-serif text-3xl sm:text-4xl font-semibold">
              From the blog
            </h2>
          </div>
          <a
            href="/posts/"
            class="text-sm font-medium text-accent-600 dark:text-accent-400 hover:underline"
          >
            All posts →
          </a>
        </div>
        <ul class="grid md:grid-cols-3 gap-5" role="list">
          {recentPosts.map((post) => (
            <li class="reveal">
              <a
                href={`/posts/${post.id}/`}
                class="block h-full rounded-xl border border-default bg-elevated p-5 hover:border-accent-400 dark:hover:border-accent-500 transition-all hover:-translate-y-1"
              >
                {post.data.category && (
                  <span class="text-xs font-medium tracking-wider uppercase text-accent-700 dark:text-accent-300">
                    {post.data.category}
                  </span>
                )}
                <h3 class="mt-2 font-serif text-xl font-semibold leading-snug">
                  {post.data.title}
                </h3>
                <p class="mt-2 text-sm text-muted line-clamp-3">
                  {post.data.description}
                </p>
                <time
                  datetime={post.data.date.toISOString()}
                  class="mt-4 block text-xs text-muted"
                >
                  {post.data.date.toLocaleDateString("en-CA", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <!-- CTA -->
  <section class="container-wide py-20">
    <div
      class="reveal relative rounded-3xl border border-default bg-elevated p-10 sm:p-14 overflow-hidden"
    >
      <div
        class="absolute -top-20 -right-20 w-80 h-80 bg-accent-500/15 rounded-full blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="relative max-w-2xl">
        <h2 class="font-serif text-3xl sm:text-4xl font-semibold">
          Let's get in touch
        </h2>
        <p class="mt-3 text-muted">
          Interested in collaboration, a guest lecture, or talking about
          research? I'm always open to thoughtful conversation.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent-600 hover:bg-accent-700 text-white font-medium text-sm transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-accent-500/25"
          >
            Send an email
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-default hover:bg-accent-50 dark:hover:bg-accent-900/20 hover:border-accent-400 dark:hover:border-accent-500 font-medium text-sm transition-all hover:-translate-y-0.5"
          >
            Contact details
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
